{
  "name": "traccia",
  "description": "A time tracking application built with Electron, React, and TypeScript.",
  "author": {
    "name": "yashpz",
    "email": "yashpz.roima@gmail.com"
  },
  "private": true,
  "version": "0.0.10",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "tsc -p tsconfig.preload.json && vite",
    "build": "tsc -b && tsc -p tsconfig.preload.json && vite build",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.preload.json",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "postinstall": "electron-builder install-app-deps",
    "publish": "npm run build:renderer && npm run build:electron && electron-builder --win --publish always",
    "dist": "npm run build:renderer && npm run build:electron && electron-builder --win",
    "release:patch": "npm version patch && git push --follow-tags",
    "release:minor": "npm version minor && git push --follow-tags",
    "release:major": "npm version major && git push --follow-tags"
  },
  "dependencies": {
    "@floating-ui/react-dom": "^2.1.8",
    "@fontsource-variable/geist": "^5.2.8",
    "@hugeicons/core-free-icons": "^4.1.1",
    "@hugeicons/react": "^1.1.6",
    "@rexa-developer/tiks": "^0.1.8",
    "@tailwindcss/vite": "^4.2.1",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.8.0",
    "motion": "^12.38.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.0",
    "shadcn": "^4.1.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "web-haptics": "^0.0.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
